+from unilog.parsers.base import BaseParser
+from unilog.registry import register_parser
+
+@register_parser
+class UnilogMockFormatter(BaseParser):
+    name = "unilog_mock"
+    description = "Mock logs format parser"
+    
+    def parse_line(self, line: str):
+        return {
+            "timestamp": "2026-07-10T12:00:00Z",
+            "level": "INFO",
+            "message": line.strip(),
+            "raw": line
+        }
