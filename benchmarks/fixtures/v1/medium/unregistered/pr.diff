+from unilog.parsers.base import BaseParser
+
+class UnregisteredCustomParser(BaseParser):
+    name = "unregistered_custom"
+    description = "Unregistered custom logs format parser"
+    
+    def parse_line(self, line: str):
+        return {
+            "timestamp": "2026-07-10T12:00:00Z",
+            "message": line
+        }
